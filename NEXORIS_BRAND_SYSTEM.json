  "motion": {
    "duration": {
      "instant": "50ms",
      "fast": "150ms",
      "normal": "200ms",
      "slow": "350ms",
      "deliberate": "500ms",
      "cinematic": "800ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "enter": "cubic-bezier(0, 0, 0.2, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)",
      "spring_default": { "type": "spring", "stiffness": 300, "damping": 30 },
      "spring_bouncy": { "type": "spring", "stiffness": 400, "damping": 20 },
      "bounce": "cubic-bezier(0.68, -0.55, 0.27, 1.55)"
    },
    "animations": {
      "page_enter": {
        "initial": { "opacity": 0, "y": 16 },
        "animate": { "opacity": 1, "y": 0 },
        "transition": { "duration": 0.35, "ease": "easeOut" }
      },
      "card_hover": {
        "whileHover": { "y": -4, "scale": 1.01 },
        "transition": { "duration": 0.2, "ease": "easeOut" }
      },
      "agent_pulse": {
        "animate": { "scale": [1, 1.15, 1], "opacity": [0.7, 1, 0.7] },
        "transition": { "duration": 2, "repeat": "Infinity", "ease": "easeInOut" }
      },
      "activity_feed_item": {
        "initial": { "opacity": 0, "x": -20 },
        "animate": { "opacity": 1, "x": 0 },
        "transition": { "duration": 0.3, "ease": "easeOut" }
      },
      "notification_bell_shake": {
        "animate": { "rotate": [-5, 5, -5, 5, -3, 3, 0] },
        "transition": { "duration": 0.5 }
      },
      "modal_enter": {
        "initial": { "opacity": 0, "scale": 0.95 },
        "animate": { "opacity": 1, "scale": 1 },
        "transition": { "duration": 0.2, "ease": "easeOut" }
      },
      "drawer_enter": {
        "initial": { "x": 400 },
        "animate": { "x": 0 },
        "transition": { "type": "spring", "stiffness": 300, "damping": 30 }
      },
      "stagger_children": {
        "parent": { "staggerChildren": 0.07 },
        "child_initial": { "opacity": 0, "y": 20 },
        "child_animate": { "opacity": 1, "y": 0 }
      },
      "kpi_counter": {
        "description": "Count up from 0 to final value over 1.5s using Framer Motion useMotionValue + useSpring"
      },
      "skeleton_shimmer": {
        "description": "CSS animation: background position moves from -200% to 200% on X axis over 1.5s infinite. Gradient: from transparent to rgba(255,255,255,0.08) to transparent."
      },
      "toast_enter": {
        "initial": { "opacity": 0, "y": -20, "scale": 0.95 },
        "animate": { "opacity": 1, "y": 0, "scale": 1 },
        "exit": { "opacity": 0, "scale": 0.95 },
        "transition": { "duration": 0.25, "ease": "easeOut" }
      }
    }
  },
