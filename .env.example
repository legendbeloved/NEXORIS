# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google APIs
GOOGLE_PLACES_API_KEY=your_places_api_key
GOOGLE_AI_API_KEY=your_gemini_api_key

# Resend (email)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=outreach@yourdomain.com
RESEND_INBOUND_WEBHOOK_SECRET=your_resend_webhook_secret

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret

# Cal.com
CAL_COM_API_KEY=your_calcom_api_key

# Internal agent communication (Railway Service URLs)
AGENT_1_URL=https://agent-1-production.up.railway.app
AGENT_2_URL=https://agent-2-production.up.railway.app
AGENT_3_URL=https://agent-3-production.up.railway.app
AGENT_WORKER_SECRET=generate_a_long_random_secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
OWNER_EMAIL=your@email.com
